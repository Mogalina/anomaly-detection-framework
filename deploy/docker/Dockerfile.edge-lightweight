FROM python:3.11-slim

LABEL maintainer="ADF Research Team"
LABEL description="Anomaly Detection Framework — Edge Node (Lightweight)"
LABEL version="1.0.0"

WORKDIR /app

# Minimal system dependencies (no database client needed)
RUN apt-get update && apt-get install -y gcc g++ && rm -rf /var/lib/apt/lists/*

# Install only the lightweight requirements
COPY requirements-edge-lightweight.txt .
RUN pip install --no-cache-dir -r requirements-edge-lightweight.txt

# Copy source and config
COPY src/ ./src/
COPY config/ ./config/

# Python path
ENV PYTHONPATH=/app/src

# Lightweight profile (no local writes)
ENV NODE_PROFILE=lightweight

# Create logs dir
RUN mkdir -p logs

# Expose metrics port (optional)
EXPOSE 9090

# Run standalone edge node entrypoint
CMD ["python", "-m", "federated.run_node"]
